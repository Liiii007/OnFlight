<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:vm="using:OnFlight.App.ViewModels"
        x:Class="OnFlight.App.Views.SettingsWindow"
        x:Name="SettingsRoot"
        Title="Settings"
        Width="680" Height="480"
        MinWidth="540" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="BorderOnly"
        CanResize="True">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Opaque background layer (beneath acrylic) -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{DynamicResource AppBackground}" IsHitTestVisible="False"/>

        <!-- ═══════ Left Column: Acrylic sidebar spanning title bar + body ═══════ -->
        <Panel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
            <ExperimentalAcrylicBorder x:Name="SidebarAcrylic" IsHitTestVisible="False">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial
                        BackgroundSource="Digger"
                        TintColor="#F7F7FA"
                        TintOpacity="0.8"
                        MaterialOpacity="0.7"/>
                </ExperimentalAcrylicBorder.Material>
            </ExperimentalAcrylicBorder>

            <DockPanel>
                <!-- Title area at top of sidebar -->
                <Panel DockPanel.Dock="Top" Height="36" PointerPressed="OnTitleBarPointerPressed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="12,0" Spacing="6">
                        <mi:MaterialIcon Kind="CogOutline" Width="14" Height="14"
                                         Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Text="Settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>
                </Panel>

                <!-- Category list -->
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Background="Transparent" BorderThickness="0"
                         Margin="8,4,8,12">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SettingsCategoryItem}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{DynamicResource AccentBlueBrush}"
                                        CornerRadius="10" Width="20" Height="20"
                                        VerticalAlignment="Center">
                                    <mi:MaterialIcon Kind="{Binding IconKind}"
                                                     Width="12" Height="12" Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryText}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Panel>

        <!-- ═══════ Right Column: Title bar row ═══════ -->
        <Border Grid.Column="1" Grid.Row="0"
                Background="{DynamicResource ContentBackground}"
                PointerPressed="OnTitleBarPointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Spacing="2" Margin="0,0,6,0">
                <Button Classes="WinBtn WinClose" Click="OnCloseClick" ToolTip.Tip="Close">
                    <mi:MaterialIcon Kind="WindowClose" Width="11" Height="11"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════ Right Column: Content body ═══════ -->
        <Border Grid.Column="1" Grid.Row="1" Background="{DynamicResource ContentBackground}">
            <DockPanel Margin="24,8,24,16">

                <!-- Content panels -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Panel>
                        <!-- General Settings -->
                        <StackPanel IsVisible="{Binding IsGeneralVisible}"
                                    Spacing="16">
                            <TextBlock Text="General" Classes="SectionHeader"/>

                            <!-- Database Directory -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Database Storage Directory" FontSize="13"
                                           Foreground="{DynamicResource SecondaryText}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding DatabaseDirectory}"
                                             Watermark="Database directory path"
                                             VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="PlainIconBtn"
                                            Click="OnBrowseDbDirectory"
                                            ToolTip.Tip="Browse..."
                                            Width="36" Height="36" Margin="4,0,0,0">
                                        <mi:MaterialIcon Kind="FolderOutline" Width="16" Height="16"
                                                         Foreground="{DynamicResource SecondaryText}"/>
                                    </Button>
                                </Grid>
                                <TextBlock Text="Where OnFlight stores its SQLite database. Changes take effect on next launch."
                                           FontSize="11" Foreground="{DynamicResource TertiaryText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Danger Zone -->
                            <Border BorderThickness="1" BorderBrush="{DynamicResource AccentRedBrush}"
                                    CornerRadius="{DynamicResource CardCornerRadius}"
                                    Padding="16,12" Opacity="0.9">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Classes="Fab" Command="{Binding ClearAllDataCommand}"
                                            Padding="12,6" VerticalAlignment="Center"
                                            Background="{DynamicResource AccentRedBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <mi:MaterialIcon Kind="DeleteForeverOutline" Width="14" Height="14"
                                                             Foreground="White"/>
                                            <TextBlock Text="Clear All" FontSize="13" Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="Clear All Data" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
                                        <TextBlock Text="Delete all lists, tasks, logs and running instances."
                                                   FontSize="11" Foreground="{DynamicResource SecondaryText}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </StackPanel>

                        <!-- Appearance Settings -->
                        <StackPanel IsVisible="{Binding IsAppearanceVisible}"
                                    Spacing="16">
                            <TextBlock Text="Appearance" Classes="SectionHeader"/>

                            <!-- Theme -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="Theme" FontSize="13"
                                           Foreground="{DynamicResource SecondaryText}"/>
                                <ComboBox ItemsSource="{Binding ThemeModeValues}"
                                          SelectedItem="{Binding SelectedThemeMode}"
                                          MinWidth="180"/>
                                <TextBlock Text="Choose between System, Light, or Dark theme."
                                           FontSize="11" Foreground="{DynamicResource TertiaryText}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Panel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
