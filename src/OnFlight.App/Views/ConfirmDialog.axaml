<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="OnFlight.App.Views.ConfirmDialog"
        Title="Confirm"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="{DynamicResource CardCornerRadius}"
            Padding="24,20"
            Margin="8"
            BoxShadow="0 4 16 0 #28000000">
        <StackPanel Spacing="16">
            <!-- Title -->
            <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryText}"
                       TextWrapping="Wrap"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText" FontSize="13"
                       Foreground="{DynamicResource SecondaryText}"
                       TextWrapping="Wrap"
                       LineHeight="20"/>

            <!-- Buttons -->
            <ItemsControl x:Name="ButtonsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
